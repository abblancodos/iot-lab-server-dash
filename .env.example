# ── GitHub Actions Runners ─────────────────────────────────────────────────
GITHUB_RUNNER_TOKEN_AGRODASH=       # GitHub → agrodash → Settings → Actions → Runners → New
GITHUB_RUNNER_TOKEN_LAB_CTL=        # GitHub → iot-lab-server-dash → Settings → Actions → Runners → New

# ── PostgreSQL réplica local ───────────────────────────────────────────────
POSTGRES_USER=agrodash
POSTGRES_PASSWORD=                  # contraseña para el PG local
POSTGRES_DB=agrodash

# ── AgroDash API ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agrodash:PASSWORD@postgres:5432/agrodash
PORT=3000
RUST_LOG=info

# ── Bucardo — fuentes físicas ──────────────────────────────────────────────
BUCARDO_SOURCE1_HOST=               # IP del primer PG físico
BUCARDO_SOURCE1_PORT=5432
BUCARDO_SOURCE1_DB=control
BUCARDO_SOURCE1_USER=postgres
BUCARDO_SOURCE1_PASS=

BUCARDO_SOURCE2_HOST=               # IP del segundo PG físico
BUCARDO_SOURCE2_PORT=5432
BUCARDO_SOURCE2_DB=control
BUCARDO_SOURCE2_USER=postgres
BUCARDO_SOURCE2_PASS=
