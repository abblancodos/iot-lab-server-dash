{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, synced_at, source, issue_type, record_id, details, resolved, resolution\n        FROM sync_audit\n        WHERE\n            ($1::text IS NULL OR issue_type = $1)\n            AND ($2::text IS NULL OR source = $2)\n            AND ($3::boolean IS NULL OR resolved = $3)\n        ORDER BY synced_at DESC\n        LIMIT $4 OFFSET $5\n        ",
